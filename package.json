{
  "name": "anssh",
  "version": "1.0.3",
  "description": "Cross-platform SSH client with Ansible inventory sync, SFTP, and host management",
  "author": "AnSSH contributors",
  "license": "MIT",
  "homepage": "https://github.com/rodinm/anssh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodinm/anssh.git"
  },
  "bugs": {
    "url": "https://github.com/rodinm/anssh/issues"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron dist/main/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:dist": "node scripts/verify-dist.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "ci": "npm run lint && npm run test && npm run build && npm run verify:dist",
    "lint": "eslint src",
    "pack": "npm run build && electron-builder --publish never",
    "pack:win": "npm run build && electron-builder --win --publish never",
    "pack:mac": "npm run build && electron-builder --mac --publish never",
    "pack:linux": "npm run build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ssh2": "^1.16.0",
    "uuid": "^9.0.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^33.4.0",
    "electron-builder": "^24.9.0",
    "eslint": "^10.1.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.anssh.app",
    "productName": "AnSSH",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "AnSSH-${version}-portable.exe"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "maintainer": "AnSSH contributors"
    }
  }
}
